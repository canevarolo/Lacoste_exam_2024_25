AA=spdiags([upd,main,downd],[1,0,-1],nn,nn);
AA(1,1)=1;
AA(1,2)=-1;
Told=Ta*ones(nn,1);
%Flusso in caso stazionario
qvol=sigma*Asc/Vol*(Tsup^4-Ta^4)+hh*Asc/Vol*(Tsup-Ta);
%Ciclo transitorio time=0;
jj=1; nmax=1e4; Tmax(jj)=Ta;
Tsuperfice(jj)=Ta; qconv(jj)=0; qirr(jj)=0; err=toll+1;
while (err>toll && jj<nmax) jj=jj+1; bb=Told+qvol/rho/cp*dt;
hcorretto=hh+sigma*(Told(end)+Ta)*(Told(end)^2+Ta^2); AA(end,end)=(1+hcorretto*dr/kk);
AA(end,end-1)=-1; bb(1)=0;
bb(end)=hcorretto*dr/kk*Ta; TT=AA\bb; Tmax(jj,1)=max(TT); Tsuperficie(jj,1)=TT(end);
qconv(jj)=hh*(Tsuperficie(jj)-Ta); qirr(jj)=sigma*(Tsuperficie(jj)^4-Ta^4);
err=abs(Tmax(jj)-Tmax(jj-1))/abs(Tmax(jj)-Ta); Told=TT;
time=time+dt;
end
 
tt=(0:dt:time)'; figure(1)
